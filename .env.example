# .env.example
# ---------------------------------------------------------
# TravelWise AI - Local Development Configuration
# ---------------------------------------------------------
# ARCHITECTURE NOTE: This file is strictly for LOCAL development and testing. 
# In production, do NOT deploy .env files. Terraform is configured to securely 
# provision these credentials directly into AWS Secrets Manager, which the 
# EC2 instance reads dynamically at boot.
#
# Instructions: Copy this file to '.env' for local testing and replace the values below.
# ---------------------------------------------------------

# --- AMADEUS API CREDENTIALS ---
# Required for live flight and hotel data.
AMADEUS_CLIENT_ID="your_client_id_here"
AMADEUS_CLIENT_SECRET="your_client_secret_here"

# --- MOCK ENGINE TOGGLE ---
# Set to 'true' to force the server to use the local simulated engine 
# (useful for offline testing or if Amadeus API quotas are exhausted).
# If credentials above are missing, the server defaults to mock mode automatically.
MOCK_MODE="false"